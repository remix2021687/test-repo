// -*- mode: jsonc -*-
{
    "layer": "top",
    "position": "top",
    "height": 11,
    "margin-top": 15,
    "margin-bottom": 0,
    "margin-left": 10,
    "margin-right": 10,
    
    "modules-left": ["clock"],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": ["hyprland/language", "network", "battery", "pulseaudio", "tray", "custom/power"],

    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "urgent": "",
            "active": "",
            "default": ""
        },

        "all-outputs": true,
        "sort-by-number": true
    },

    "clock": {
        "format": "   {:%H:%M}",
        "format-alt": "   {:%d.%m.%Y}",
        "tooltip-format": "<big>{:%Y %B %d}</big>\n<tt><small>{calendar}</small></tt>",
    },

    "hyprland/language": {
        "format": "Lang: {long}",
	    // "format-en": "AMERICA, HELL YEAH!",
	    // "format-cz": "As bayrakları",
	    
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "󰝟",
        "format-icons": ["  ", "  ", "  "]
    },

    "network": {
        "format-wifi": "      {essid}",
        "format-ethernet": "󰈀    {ipaddr}",
        "format-disconnected": "⚠   Нет сети",
        "tooltip-format": "{ifname} {ipaddr}"
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": ["   ", "   ", "   ", "   ", "   "],
        "format-charging": "   {capacity}%"
    },

    "custom/power": {
        "format": "⏻",
        "tooltip": false,
        "menu": "on-click",                     
        "menu-file": "~/.config/waybar/menu/power_menu.xml",
        "menu-actions": {
            "shutdown": "poweroff",
            "reboot": "reboot",
            "suspend": "systemctl suspend",
            "hibernate": "systemctl hibernate",
            "lock": "hyprlock",
        },
    },

    "tray": {
        "spacing": 8
    },
}
